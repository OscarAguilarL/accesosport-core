# Base de datos
DB_URL=jdbc:postgresql://localhost:5432/carreras_db
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME

# Cloudinary (almacenamiento de imágenes)
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME

APP_ENV=local

# JWT
APP_JWT_SECRET=CHANGE_ME_use_a_long_random_string_of_at_least_32_chars
APP_JWT_EXPIRATION=86400000
APP_JWT_REFRESH_EXPIRATION=604800000

# Admin bootstrap (solo desarrollo)
APP_ADMIN_ENABLED=true
APP_ADMIN_EMAIL=admin@accesosport.com
APP_ADMIN_PASSWORD=CHANGE_ME

# Scheduler de ciclo de vida de eventos
# APP_SCHEDULER_LIFECYCLE_DELAY_MS: intervalo en ms entre ejecuciones del scheduler (default: 60000 = 1 min)
# APP_SCHEDULER_COMPLETE_AFTER_HOURS: horas tras el inicio del evento para marcarlo como COMPLETED automáticamente (default: 12)
APP_SCHEDULER_LIFECYCLE_DELAY_MS=60000
APP_SCHEDULER_COMPLETE_AFTER_HOURS=12

# Servidor
SERVER_PORT=8080

# CORS (separar múltiples orígenes con coma)
APP_CORS_ALLOWED_ORIGINS=http://localhost:*

# Docker / PostgreSQL
POSTGRES_DB=carreras_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@carreras.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME
