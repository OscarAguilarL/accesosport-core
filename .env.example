# ─────────────────────────────────────────────
# LOCAL (docker-compose)
# ─────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/carreras_db
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME

# Docker / PostgreSQL (solo para docker-compose local)
POSTGRES_DB=carreras_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# PgAdmin (solo local)
PGADMIN_DEFAULT_EMAIL=admin@carreras.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME

# ─────────────────────────────────────────────
# RAILWAY (staging / production)
# Construir DB_URL con variables individuales de Railway Postgres:
#   DB_URL=jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
#   DB_USERNAME=${{Postgres.PGUSER}}
#   DB_PASSWORD=${{Postgres.PGPASSWORD}}
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# COMPARTIDAS (todos los ambientes)
# ─────────────────────────────────────────────

# JWT
APP_JWT_SECRET=CHANGE_ME_use_a_long_random_string_of_at_least_32_chars
APP_JWT_EXPIRATION=86400000
APP_JWT_REFRESH_EXPIRATION=604800000

# CORS — separar múltiples orígenes con coma
# staging:    https://staging.accesosport.com,https://tu-proyecto.vercel.app
# production: https://app.accesosport.com
APP_CORS_ALLOWED_ORIGINS=http://localhost:*

# Cloudinary
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME
APP_ENV=local   # local | staging | production

# Email (Resend)
RESEND_API_KEY=CHANGE_ME
RESEND_FROM_EMAIL=noreply@accesosport.com

# Admin bootstrap — deshabilitar (false) tras el primer deploy
APP_ADMIN_ENABLED=true
APP_ADMIN_EMAIL=admin@accesosport.com
APP_ADMIN_PASSWORD=CHANGE_ME

# Servidor
SERVER_PORT=8080

# Scheduler (defaults razonables — solo sobreescribir si es necesario)
# APP_SCHEDULER_LIFECYCLE_DELAY_MS=60000
# APP_SCHEDULER_COMPLETE_AFTER_HOURS=12
# APP_SCHEDULER_REMINDER_DELAY_MS=3600000
# APP_CHECKIN_TOKEN_VALID_HOURS=12
